# GIS 공급자 선택 (kakao | naver | vworld)
NEXT_PUBLIC_MAP_PROVIDER=kakao

# GIS API 키
# Kakao: https://developers.kakao.com/console/app
NEXT_PUBLIC_KAKAO_APP_KEY=

# Naver: https://developers.naver.com/products/map/maps
NEXT_PUBLIC_NAVER_CLIENT_ID=

# VWORLD: https://www.vworld.kr/api/
NEXT_PUBLIC_VWORLD_API_KEY=

# API 백엔드 URL
# 빈값 = Next.js 목 API 사용 (/api/mock)
# 설정값 = 실 백엔드 연결 (예: http://localhost:8080/api)
NEXT_PUBLIC_API_BASE_URL=
